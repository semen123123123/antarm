# RoboKassa (online kassa)
# Shop ID and passwords from: https://partner.robokassa.ru/
ROBOKASSA_SHOP_ID=your_shop_id
ROBOKASSA_PASS_1=your_password_1
ROBOKASSA_PASS_2=your_password_2
ROBOKASSA_TEST=true

# Server
JWT_SECRET=your-jwt-secret-change-in-production
NODE_ENV=development

# CORS (for production, set your frontend domain)
CORS_ORIGIN=http://localhost:3000
